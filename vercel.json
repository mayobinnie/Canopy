{
  "rewrites": [
    { "source": "/counter-uas-drone-defeat", "destination": "/counter-uas-drone-defeat.html" },
    { "source": "/drone-thermal-survey-uk", "destination": "/drone-thermal-survey-uk.html" },
    { "source": "/drone-inspection-uk", "destination": "/drone-inspection-uk.html" },
    { "source": "/photogrammetry-mapping-uk", "destination": "/photogrammetry-mapping-uk.html" },
    { "source": "/digital-twin-generation-uk", "destination": "/digital-twin-generation-uk.html" },
    { "source": "/lidar-survey-uk", "destination": "/lidar-survey-uk.html" },
    { "source": "/cni-drone-security", "destination": "/cni-drone-security.html" },
    { "source": "/drone-defeat-energy-infrastructure", "destination": "/drone-defeat-energy-infrastructure.html" },
    { "source": "/drone-defeat-ports-maritime", "destination": "/drone-defeat-ports-maritime.html" },
    { "source": "/drone-survey-humber", "destination": "/drone-survey-humber.html" },
    { "source": "/thermal-survey-industrial-estates", "destination": "/thermal-survey-industrial-estates.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
